# Copy this file to .env and fill values (do not commit .env).
#
# SQL Server SA password must meet complexity rules:
# - >= 8 chars, includes upper, lower, number, and symbol.
MSSQL_SA_PASSWORD=ChangeThis_Strong_SA_Password_123!

# SQL Server connection string used by the API.
# If you use the docker-compose.yml in this repo, the SQL host is "db".
CONNECTIONSTRINGS__SQLSERVER=Server=db,1433;Database=B2B;User Id=sa;Password=ChangeThis_Strong_SA_Password_123!;TrustServerCertificate=True;

# JWT signing secret (use 32+ random chars).
JWT__SIGNINGKEY=REPLACE_WITH_RANDOM_32+_CHAR_SECRET________________

