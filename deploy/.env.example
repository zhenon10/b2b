# Copy this file to .env and fill values (do not commit .env).
#
# SQL Server SA password must meet complexity rules:
# - >= 8 chars, includes upper, lower, number, and symbol.
MSSQL_SA_PASSWORD=ChangeThis_Strong_SA_Password_123!

# SQL Server connection string used by the API.
# If you use the docker-compose.yml in this repo, the SQL host is "db".
CONNECTIONSTRINGS__SQLSERVER=Server=db,1433;Database=B2B;User Id=sa;Password=ChangeThis_Strong_SA_Password_123!;TrustServerCertificate=True;

# JWT signing secret (use 32+ random chars).
JWT__SIGNINGKEY=REPLACE_WITH_RANDOM_32+_CHAR_SECRET________________

# Optional: API public URL (used when generating absolute links, etc.)
# Example (domain): https://api.example.com
# Example (tailscale): http://100.x.y.z:8080
API__PUBLICBASEURL=

# Optional: object storage mode and public base url.
# - Local (default): files served from /wwwroot/uploads (API must be reachable publicly if you return absolute URLs)
# - S3: use an S3-compatible provider (MinIO, AWS S3, etc.) and set its PublicBaseUrl.
OBJECTSTORAGE__PROVIDER=Local
OBJECTSTORAGE__PUBLICBASEURL=

# Optional: CORS allowed origins (frontend/mobile webviews etc.)
# Examples:
# CORS__ALLOWEDORIGINS__0=https://admin.example.com
# CORS__ALLOWEDORIGINS__1=https://shop.example.com
CORS__ALLOWEDORIGINS__0=
CORS__ALLOWEDORIGINS__1=
CORS__ALLOWEDORIGINS__2=

