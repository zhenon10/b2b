# Example environment variables for B2B.Api (do not commit a filled-in copy).
# ASP.NET Core maps double underscores to nested configuration keys.
#
# Local development (PowerShell), from repo root:
#   dotnet user-secrets set "ConnectionStrings:SqlServer" "Server=(localdb)\\MSSQLLocalDB;Database=B2B;Trusted_Connection=True;TrustServerCertificate=True" --project B2B.Api/B2B.Api.csproj
#   dotnet user-secrets set "Jwt:SigningKey" "REPLACE_WITH_RANDOM_32+_CHAR_SECRET________________" --project B2B.Api/B2B.Api.csproj
#   dotnet user-secrets set "Seed:AdminPassword" "your-secure-admin-password" --project B2B.Api/B2B.Api.csproj
#   dotnet user-secrets set "Seed:BuyerPassword" "your-secure-dealer-password" --project B2B.Api/B2B.Api.csproj
#
# Production / containers: inject the same keys via your platform (Key Vault, sealed secrets, etc.).
#
# Open Dealer self-service signup: false in production; true only for dev/demo.
Auth__AllowPublicRegistration=false
# Skip admin approval for new Dealers (tests only; keep false in real environments).
Auth__AutoApproveRegisteredDealers=false

ConnectionStrings__SqlServer=
Jwt__SigningKey=
# Access token (minutes) + opaque refresh token (days). Shorter access + refresh improves mobile reliability.
# Jwt__AccessTokenMinutes=15
# Jwt__RefreshTokenDays=14
# Seed passwords required when Seed__Mode is RolesAndAdmin or Demo (see appsettings / env).
Seed__AdminPassword=
Seed__BuyerPassword=
# Optional aliases used by seeder for Demo mode:
# Seed__DealerPassword=
# Seed__DealerEmail=

# Product image URLs stored with an old LAN IP: rewrite to current API host (dev-friendly). Keep false in production unless you fully trust your DB.
# PublicAssets__RewritePrivateLanUploadUrls=false

# Public URL of the API as seen by browsers/mobile (no trailing path). Use behind reverse proxy when Request.Host is internal.
# Api__PublicBaseUrl=https://api.example.com

# Swagger UI + OpenAPI JSON. Defaults: off in Production; on when ASPNETCORE_ENVIRONMENT=Development.
# Set true only on trusted networks (e.g. staging) when not using Development environment.
# Api__EnableSwagger=false
