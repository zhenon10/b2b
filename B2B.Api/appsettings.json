{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Properties": {
      "Application": "B2B.Api"
    }
  },
  "ConnectionStrings": {
    "SqlServer": ""
  },
  "Jwt": {
    "Issuer": "B2B.Api",
    "Audience": "B2B.Mobile",
    "AccessTokenMinutes": 60
  },
  "Seed": {
    "Mode": "Off",
    "AdminEmail": "admin@b2b.local",
    "SellerEmail": "seller@b2b.local",
    "BuyerEmail": "buyer@b2b.local"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Auth": {
    "AllowPublicRegistration": false,
    "AutoApproveRegisteredDealers": false
  },
  "AllowedHosts": "*",
  "Api": {
    "PublicBaseUrl": ""
  },
  "PublicAssets": {
    "RewritePrivateLanUploadUrls": false
  }
}
