{
  "Api": {
    "EnableSwagger": true
  },
  "PublicAssets": {
    "RewritePrivateLanUploadUrls": true
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Auth": {
    "AllowPublicRegistration": true,
    "AutoApproveRegisteredDealers": false
  },
  "Uploads": {
    "DailyMaxCount": 200,
    "DailyMaxBytes": 209715200
  },
  "ObjectStorage": {
    "Provider": "Local",
    "PublicBaseUrl": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5237",
      "https://localhost:7231",
      "http://localhost:5000"
    ]
  },
  "Seed": {
    "Mode": "Demo"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
