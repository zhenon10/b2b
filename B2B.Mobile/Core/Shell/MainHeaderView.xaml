<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="B2B.Mobile.Core.Shell.MainHeaderView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">

    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="0">
        <Label
            x:Name="LeftCaptionLabel"
            Grid.Column="0"
            Text="{Binding LeftCaption, Source={x:Reference Root}}"
            Style="{StaticResource Caption}"
            VerticalOptions="Center"
            LineBreakMode="TailTruncation"
            IsVisible="{Binding LeftCaption, Source={x:Reference Root}, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
        <Label
            x:Name="UsdLabel"
            Grid.Column="1"
            Style="{StaticResource Caption}"
            FontAttributes="Bold"
            VerticalOptions="Center"
            HorizontalTextAlignment="End" />
    </Grid>
</ContentView>
