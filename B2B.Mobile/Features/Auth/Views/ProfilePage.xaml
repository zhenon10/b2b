<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Auth.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shell="clr-namespace:B2B.Mobile.Core.Shell"
    Title="Profil">

    <Grid RowDefinitions="Auto,*">
        <shell:MainHeaderView Grid.Row="0" Padding="16,12,16,0" />
        <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="16" Spacing="14">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Border Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Hesap bilgileri" Style="{StaticResource Title2}" />
                    <Label Text="E-posta" Style="{StaticResource Caption}" />
                    <Label Text="{Binding ProfileEmail}" FontAttributes="Bold" />
                    <Label Text="Görünen ad" Style="{StaticResource Caption}" />
                    <Label Text="{Binding ProfileDisplayName}" />
                    <Label Text="Roller" Style="{StaticResource Caption}" />
                    <Label Text="{Binding ProfileRoles}" />
                    <Label Text="Durum" Style="{StaticResource Caption}" />
                    <Label Text="{Binding AccountStatus}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Şifre değiştir" Style="{StaticResource Title2}" />

                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Mevcut şifre" IsPassword="True" Text="{Binding CurrentPassword}" />
                    </Border>
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Yeni şifre (en az 8 karakter)" IsPassword="True" Text="{Binding NewPassword}" />
                    </Border>
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Yeni şifre (tekrar)" IsPassword="True" Text="{Binding ConfirmPassword}" />
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="12" IsVisible="{Binding Error, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <Label Text="{Binding Error}" TextColor="{StaticResource Error}" />
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="12" IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <Label Text="{Binding SuccessMessage}" TextColor="{StaticResource Primary}" />
                    </Border>

                    <Button Text="Şifreyi güncelle"
                            Command="{Binding ChangePasswordCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Çıkış yap"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding LogoutCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
