<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Auth.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ui="clr-namespace:B2B.Mobile.Core.Ui;assembly=B2B.Mobile"
    xmlns:str="clr-namespace:B2B.Mobile.Resources.Strings;assembly=B2B.Mobile"
    Title="{x:Static str:AppStrings.Login_PageTitle}">

    <ScrollView>
        <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="18">
            <VerticalStackLayout Grid.Row="0" Spacing="6">
                <Label Text="{x:Static str:AppStrings.Login_WelcomeTitle}" Style="{StaticResource TitleLarge}" SemanticProperties.HeadingLevel="Level1" />
                <Label Text="{x:Static str:AppStrings.Login_WelcomeSubtitle}" Style="{StaticResource Caption}" />
            </VerticalStackLayout>

            <Border Grid.Row="1"
                    Padding="12"
                    Style="{StaticResource Card}"
                    IsVisible="{Binding InfoBanner, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                <Label Text="{Binding InfoBanner}"
                       Style="{StaticResource Caption}"
                       TextColor="{StaticResource Primary}"
                       SemanticProperties.Description="{Binding InfoBanner}" />
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="{x:Static str:AppStrings.Login_EmailPlaceholder}"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               SemanticProperties.Hint="{x:Static str:AppStrings.Login_EmailHint}" />
                    </Border>
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="{x:Static str:AppStrings.Login_PasswordPlaceholder}"
                               IsPassword="True"
                               Text="{Binding Password}"
                               SemanticProperties.Hint="{x:Static str:AppStrings.Login_PasswordHint}" />
                    </Border>

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <CheckBox IsChecked="{Binding RememberMe}"
                                  VerticalOptions="Center"
                                  SemanticProperties.Description="{x:Static str:AppStrings.Login_RememberMeHint}" />
                        <Label Text="{x:Static str:AppStrings.Login_RememberMeLabel}"
                               VerticalOptions="Center"
                               Style="{StaticResource Caption}" />
                    </HorizontalStackLayout>

                    <ui:ApiErrorBannerView Message="{Binding Error}" TraceId="{Binding ApiTraceId}" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="{x:Static str:AppStrings.Login_Submit}"
                                SemanticProperties.Hint="{x:Static str:AppStrings.Login_SubmitHint}"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                    </Grid>

                    <Button Text="{x:Static str:AppStrings.Login_Register}"
                            SemanticProperties.Hint="{x:Static str:AppStrings.Login_RegisterHint}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding GoToRegisterCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
