<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Auth.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ui="clr-namespace:B2B.Mobile.Core.Ui;assembly=B2B.Mobile"
    xmlns:str="clr-namespace:B2B.Mobile.Resources.Strings;assembly=B2B.Mobile"
    Title="{x:Static str:AppStrings.Register_PageTitle}">

    <ScrollView>
        <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="18">
            <VerticalStackLayout Grid.Row="0" Spacing="6">
                <Label Text="{x:Static str:AppStrings.Register_Headline}" Style="{StaticResource TitleLarge}" SemanticProperties.HeadingLevel="Level1" />
                <Label Text="{x:Static str:AppStrings.Register_Subtitle}" Style="{StaticResource Caption}" />
            </VerticalStackLayout>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="{x:Static str:AppStrings.Register_DisplayNamePlaceholder}"
                               Text="{Binding DisplayName}"
                               SemanticProperties.Hint="{x:Static str:AppStrings.Register_DisplayNamePlaceholder}" />
                    </Border>
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="{x:Static str:AppStrings.Register_EmailPlaceholder}"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               SemanticProperties.Hint="{x:Static str:AppStrings.Register_EmailPlaceholder}" />
                    </Border>
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="{x:Static str:AppStrings.Register_PasswordPlaceholder}"
                               IsPassword="True"
                               Text="{Binding Password}"
                               SemanticProperties.Hint="{x:Static str:AppStrings.Register_PasswordPlaceholder}" />
                    </Border>
                    <Label Style="{StaticResource Caption}"
                           Text="{x:Static str:AppStrings.Register_PasswordRules}"
                           LineBreakMode="WordWrap" />

                    <ui:ApiErrorBannerView Message="{Binding Error}" TraceId="{Binding ApiTraceId}" />

                    <Border Style="{StaticResource Card}" Padding="12" IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding SuccessMessage}" SemanticProperties.Description="{Binding SuccessMessage}" />
                            <Button Text="{x:Static str:AppStrings.Register_GoLogin}"
                                    SemanticProperties.Hint="{x:Static str:AppStrings.Register_GoLoginHint}"
                                    Clicked="OnGoLoginClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="{x:Static str:AppStrings.Register_Submit}"
                                SemanticProperties.Hint="{x:Static str:AppStrings.Register_SubmitHint}"
                                Command="{Binding RegisterCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
