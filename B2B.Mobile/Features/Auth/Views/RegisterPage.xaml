<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Auth.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Kayıt">

    <ScrollView>
        <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="18">
            <VerticalStackLayout Grid.Row="0" Spacing="6">
                <Label Text="Hesap oluştur" Style="{StaticResource TitleLarge}" />
                <Label Text="Sipariş vermeye başlamak için kayıt olun." Style="{StaticResource Caption}" />
            </VerticalStackLayout>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Görünen ad" Text="{Binding DisplayName}" />
                    </Border>
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="E-posta" Keyboard="Email" Text="{Binding Email}" />
                    </Border>
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Şifre" IsPassword="True" Text="{Binding Password}" />
                    </Border>
                    <Label Style="{StaticResource Caption}"
                           Text="Şifre: en az 8 karakter; büyük ve küçük harf, rakam ve sembol (!@# vb.) zorunlu."
                           LineBreakMode="WordWrap" />

                    <Border Style="{StaticResource Card}" Padding="12" IsVisible="{Binding Error, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <Label Text="{Binding Error}" TextColor="{StaticResource Error}" />
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="12" IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding SuccessMessage}" />
                            <Button Text="Giriş sayfasına git" Clicked="OnGoLoginClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="Kayıt ol"
                                Command="{Binding RegisterCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
