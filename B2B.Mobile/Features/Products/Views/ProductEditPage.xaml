<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Products.Views.ProductEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Ürün">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Border Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Temel bilgiler" Style="{StaticResource Title2}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Border Grid.Column="0" Style="{StaticResource InputContainer}">
                            <Entry Placeholder="SKU" Text="{Binding Sku}" />
                        </Border>
                        <Button Grid.Column="1"
                                Text="Tara"
                                Style="{StaticResource SecondaryButton}"
                                VerticalOptions="Center"
                                Command="{Binding ScanSkuCommand}" />
                    </Grid>
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Ürün adı" Text="{Binding Name}" />
                    </Border>
                    <Border Style="{StaticResource InputContainer}">
                        <Editor Placeholder="Açıklama" Text="{Binding Description}" AutoSize="TextChanges" />
                    </Border>

                    <Label Text="Kategori" Style="{StaticResource Caption}" />
                    <Border Style="{StaticResource InputContainer}">
                        <Picker Title="Kategori seçin"
                                ItemsSource="{Binding CategoryOptions}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedCategory}" />
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="Para birimi" Style="{StaticResource Caption}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="Stok adedi" Style="{StaticResource Caption}" />

                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource InputContainer}">
                            <Entry Placeholder="TRY" Text="{Binding CurrencyCode}" />
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource InputContainer}">
                            <Entry Placeholder="0" Keyboard="Numeric" Text="{Binding StockQuantity}" />
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="Bayi fiyatı" Style="{StaticResource Caption}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="Tavsiye satış (MSRP)" Style="{StaticResource Caption}" />

                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource InputContainer}">
                            <Entry Placeholder="0.00" Keyboard="Numeric" Text="{Binding DealerPrice}" />
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource InputContainer}">
                            <Entry Placeholder="0.00" Keyboard="Numeric" Text="{Binding MsrpPrice}" />
                        </Border>
                    </Grid>

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Label Text="Aktif" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding IsActive}" />
                    </HorizontalStackLayout>

                    <Border Style="{StaticResource Card}" Padding="12" IsVisible="{Binding Error, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <Label Text="{Binding Error}" TextColor="{StaticResource Error}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Görseller" Style="{StaticResource Title2}" />
                        <Button Grid.Column="1" Text="Satır ekle" Style="{StaticResource SecondaryButton}" Command="{Binding AddImageCommand}" />
                    </Grid>

                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Kamera" Command="{Binding AddPhotoFromCameraCommand}" />
                        <Button Text="Galeri" Style="{StaticResource SecondaryButton}" Command="{Binding AddPhotoFromGalleryCommand}" />
                    </HorizontalStackLayout>

                    <CollectionView ItemsSource="{Binding Images}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10" Padding="0,6">
                                    <RadioButton GroupName="primaryImg" IsChecked="{Binding IsPrimary}" VerticalOptions="Center" />
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="{AppThemeBinding Light='#F1F3F5', Dark='#1F2226'}">
                                        <Image Source="{Binding Url}"
                                               HeightRequest="44"
                                               WidthRequest="44"
                                               Aspect="AspectFill" />
                                    </Border>
                                    <Entry Grid.Column="2" Placeholder="https://..." Text="{Binding Url}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="Özellikler" Style="{StaticResource Title2}" />
                        <Button Grid.Column="1" Text="Ekle" Style="{StaticResource SecondaryButton}" Command="{Binding AddSpecCommand}" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Specs}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Padding="0,6">
                                    <Entry Placeholder="Anahtar" Text="{Binding Key}" />
                                    <Entry Grid.Column="1" Placeholder="Değer" Text="{Binding Value}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Button Text="Ürünü sil"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding DeleteProductCommand}"
                    IsVisible="{Binding CanDeleteProduct}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

            <Button Text="Kaydet"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

