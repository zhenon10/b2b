<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Products.Views.CategoryAdminPage"
    x:Name="ThisPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:B2B.Mobile.Features.Products.ViewModels"
    xmlns:models="clr-namespace:B2B.Mobile.Features.Products.Models"
    x:DataType="vm:CategoryAdminViewModel"
    Title="Kategori yönetimi">

    <Grid RowDefinitions="Auto,*,Auto" Padding="12" RowSpacing="12">
        <Label Grid.Row="0"
               Text="Kategori ekleyin, düzenleyin veya silin. Silinen kategorideki ürünler kategorisiz kalır."
               Style="{StaticResource Caption}" />

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="Henüz kategori yok. Araç çubuğundan + ile ekleyin."
                           Style="{StaticResource Caption}"
                           HorizontalTextAlignment="Center"
                           Margin="0,32,0,0" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:CategoryListItem">
                        <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" RowSpacing="8">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" />
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding SortOrder, StringFormat='Sıra: {0}'}" Style="{StaticResource Caption}" />
                                        <Label Text="•" Style="{StaticResource Caption}" />
                                        <Label Text="Aktif" Style="{StaticResource Caption}" IsVisible="{Binding IsActive}" />
                                        <Label Text="Pasif" Style="{StaticResource Caption}" IsVisible="{Binding IsActive, Converter={StaticResource InverseBoolConverter}}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="6">
                                    <Button Text="Düzenle"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.EditCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="Sil"
                                            Style="{StaticResource DestructiveButton}"
                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DeleteCommand}"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Border Grid.Row="2"
                Padding="12"
                BackgroundColor="{AppThemeBinding Light=#FFF3CD, Dark=#3D3500}"
                StrokeThickness="0"
                IsVisible="{Binding Error, Converter={StaticResource StringNotNullOrEmptyConverter}}">
            <Label Text="{Binding Error}" TextColor="{StaticResource Error}" />
        </Border>
    </Grid>
</ContentPage>
