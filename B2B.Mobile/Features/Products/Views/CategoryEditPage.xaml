<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Products.Views.CategoryEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:B2B.Mobile.Features.Products.ViewModels"
    xmlns:ui="clr-namespace:B2B.Mobile.Core.Ui;assembly=B2B.Mobile"
    x:DataType="vm:CategoryEditViewModel"
    Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <ui:ApiErrorBannerView Message="{Binding Error}" TraceId="{Binding ApiTraceId}" />

            <Label Text="Ad" Style="{StaticResource Caption}" />
            <Border Style="{StaticResource InputContainer}">
                <Entry Text="{Binding Name}" Placeholder="Kategori adı" />
            </Border>

            <Label Text="Sıra (listede küçük önce)" Style="{StaticResource Caption}" />
            <Stepper Minimum="0"
                     Maximum="9999"
                     Increment="1"
                     Value="{Binding SortOrder}"
                     HorizontalOptions="Start" />

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Switch IsToggled="{Binding IsActive}" />
                <Label Text="Aktif" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Button Text="Kaydet"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
