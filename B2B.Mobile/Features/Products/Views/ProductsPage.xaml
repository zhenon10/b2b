<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Products.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shell="clr-namespace:B2B.Mobile.Core.Shell"
    xmlns:models="clr-namespace:B2B.Mobile.Features.Products.Models"
    xmlns:ui="clr-namespace:B2B.Mobile.Core.Ui;assembly=B2B.Mobile"
    xmlns:str="clr-namespace:B2B.Mobile.Resources.Strings;assembly=B2B.Mobile"
    Title="Ürünler">

    <Grid RowDefinitions="Auto,Auto,*" Padding="12" RowSpacing="8">
        <shell:MainHeaderView Grid.Row="0"
                              LeftCaption="{Binding FilterSummary, StringFormat='Kategori: {0}'}" />

        <!-- Arama + tara: tek satır, tara kompakt -->
        <Border Grid.Row="1"
                Style="{StaticResource InputContainer}"
                Padding="6,4">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6" VerticalOptions="Center">
                <SearchBar Grid.Column="0"
                           Placeholder="{x:Static str:AppStrings.Product_SearchPlaceholder}"
                           SemanticProperties.Hint="{x:Static str:AppStrings.Product_SearchHint}"
                           Text="{Binding Query}"
                           SearchCommand="{Binding RefreshCommand}"
                           BackgroundColor="Transparent"
                           HorizontalOptions="Fill"
                           VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="Tara"
                        SemanticProperties.Description="{x:Static str:AppStrings.Products_ScanHint}"
                        BackgroundColor="Transparent"
                        BorderColor="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource Gray600}}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        FontSize="12"
                        Padding="10,6"
                        MinimumWidthRequest="52"
                        MaximumWidthRequest="68"
                        HeightRequest="40"
                        CornerRadius="10"
                        VerticalOptions="Center"
                        Command="{Binding ScanCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
            <Border
                Grid.Row="0"
                Style="{StaticResource Card}"
                Padding="10,6"
                IsVisible="{Binding ScanFilterCode, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                    <Label
                        Grid.Column="0"
                        Text="{Binding ScanFilterCode, StringFormat='Barkod: {0}'}"
                        Style="{StaticResource Caption}"
                        LineBreakMode="TailTruncation" />
                    <Button
                        Grid.Column="1"
                        Text="✕"
                        Style="{StaticResource SecondaryButton}"
                        FontSize="14"
                        Padding="0"
                        WidthRequest="36"
                        HeightRequest="36"
                        CornerRadius="18"
                        SemanticProperties.Description="Barkod filtresini temizle"
                        Command="{Binding ClearScanFilterCommand}" />
                </Grid>
            </Border>

            <HorizontalStackLayout
                Grid.Row="1"
                Spacing="8"
                IsVisible="{Binding CanManageProducts}"
                VerticalOptions="Center">
                <Label Text="Pasif ürünleri göster"
                       Style="{StaticResource Caption}"
                       VerticalOptions="Center" />
                <Switch IsToggled="{Binding IncludeInactiveProducts}"
                        VerticalOptions="Center"
                        SemanticProperties.Description="Yönetici için pasif ürünleri katalogda gösterir veya gizler" />
            </HorizontalStackLayout>

            <VerticalStackLayout
                Grid.Row="2"
                Spacing="8"
                IsVisible="{Binding Error, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                <ui:ApiErrorBannerView Message="{Binding Error}" TraceId="{Binding ApiTraceId}" />
                <Button Text="Yeniden dene"
                        SemanticProperties.Hint="Ürün listesini yeniden yükler"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshCommand}" />
            </VerticalStackLayout>

            <Grid Grid.Row="3" RowDefinitions="*" ColumnDefinitions="*">
                <CollectionView
                    IsVisible="{Binding ShowSkeleton}"
                    SelectionMode="None"
                    VerticalOptions="Fill"
                    HorizontalOptions="Fill">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="{Binding CatalogColumns}" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemsSource>
                        <x:Array Type="{x:Type x:Int32}">
                            <x:Int32>1</x:Int32>
                            <x:Int32>2</x:Int32>
                            <x:Int32>3</x:Int32>
                            <x:Int32>4</x:Int32>
                            <x:Int32>5</x:Int32>
                            <x:Int32>6</x:Int32>
                        </x:Array>
                    </CollectionView.ItemsSource>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,4" Opacity="0.70">
                                <VerticalStackLayout Spacing="0">
                                    <BoxView HeightRequest="168"
                                             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}" />
                                    <VerticalStackLayout Padding="12,10,12,12" Spacing="10">
                                        <BoxView HeightRequest="14" CornerRadius="6"
                                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" />
                                        <BoxView HeightRequest="12" CornerRadius="6"
                                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" />
                                        <BoxView HeightRequest="18" WidthRequest="90" CornerRadius="6"
                                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" />
                                        <BoxView HeightRequest="40" CornerRadius="12"
                                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <RefreshView
                    IsRefreshing="{Binding IsRefreshing}"
                    Command="{Binding RefreshCommand}"
                    IsVisible="{Binding ShowSkeleton, Converter={StaticResource InverseBoolConverter}}"
                    VerticalOptions="Fill"
                    HorizontalOptions="Fill">
                    <CollectionView x:Name="ProductsCollection"
                        ItemsSource="{Binding Items}"
                        RemainingItemsThreshold="6"
                        RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged"
                        VerticalOptions="Fill"
                        HorizontalOptions="Fill">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="24" Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding CatalogEmptyTitle}" Style="{StaticResource Title}" HorizontalTextAlignment="Center" />
                            <Label Text="{Binding CatalogEmptyHint}" Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                            <Button Text="Aramayı temizle"
                                    IsVisible="{Binding Query, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                    SemanticProperties.Hint="Arama metnini temizler ve kataloğu yeniden yükler"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ClearQueryCommand}" />
                            <Button Text="Yenile"
                                    SemanticProperties.Hint="Kataloğu yeniden yükler"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RefreshCommand}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProductListItem">
                            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,4">
                                <VerticalStackLayout Spacing="0">
                                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource CatalogImageBgLight}, Dark={StaticResource CatalogImageBgDark}}"
                                            StrokeThickness="0"
                                            HeightRequest="168"
                                            StrokeShape="RoundRectangle 12,12,0,0">
                                        <Grid IsClippedToBounds="True">
                                            <Image Source="{Binding PrimaryImageUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                   Aspect="AspectFill"
                                                   HorizontalOptions="Fill"
                                                   VerticalOptions="Fill"
                                                   SemanticProperties.Description="Ürün görseli" />
                                        </Grid>
                                    </Border>

                                    <Border BackgroundColor="{StaticResource Gray600}"
                                            StrokeThickness="0"
                                            Padding="8,5"
                                            IsVisible="{Binding IsActive, Converter={StaticResource InverseBoolConverter}}">
                                        <Label Text="Pasif ürün"
                                               TextColor="White"
                                               FontSize="11"
                                               FontAttributes="Bold" />
                                    </Border>

                                    <Border BackgroundColor="{StaticResource Error}"
                                            StrokeThickness="0"
                                            Padding="8,5">
                                        <Border.IsVisible>
                                            <MultiBinding Converter="{StaticResource ActiveAndOutOfStockConverter}">
                                                <Binding Path="IsActive" />
                                                <Binding Path="StockQuantity" />
                                            </MultiBinding>
                                        </Border.IsVisible>
                                        <Label Text="Stokta yok"
                                               TextColor="White"
                                               FontSize="11"
                                               FontAttributes="Bold" />
                                    </Border>

                                    <Border BackgroundColor="{StaticResource Tertiary}"
                                            StrokeThickness="0"
                                            Padding="8,5">
                                        <Border.IsVisible>
                                            <MultiBinding Converter="{StaticResource ActiveAndLowStockConverter}">
                                                <Binding Path="IsActive" />
                                                <Binding Path="StockQuantity" />
                                            </MultiBinding>
                                        </Border.IsVisible>
                                        <Label Text="{Binding StockQuantity, StringFormat='Az stok: {0}'}"
                                               TextColor="White"
                                               FontSize="11"
                                               FontAttributes="Bold" />
                                    </Border>

                                    <VerticalStackLayout Padding="12,10,12,12" Spacing="6">
                                        <Label Text="{Binding Name}"
                                               FontSize="13"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray200}}" />

                                        <!-- SKU/kategori yoğunluğunu azalt: SKU yalnızca admin için (debug) gösterilir -->
                                        <Label Text="{Binding Sku, StringFormat='SKU: {0}'}"
                                               Style="{StaticResource Caption}"
                                               LineBreakMode="TailTruncation"
                                               IsVisible="{Binding BindingContext.CanManageProducts, Source={RelativeSource AncestorType={x:Type ContentPage}}}" />

                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding DealerPrice, StringFormat='{0:0.##}'}"
                                                   FontAttributes="Bold"
                                                   FontSize="17"
                                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                                   VerticalOptions="End" />
                                            <Label Text="{Binding CurrencyCode}"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                                   VerticalOptions="End" />
                                        </HorizontalStackLayout>

                                        <Label Text="{Binding MsrpPrice, StringFormat='{0:0.##}'}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                               TextDecorations="Strikethrough">
                                            <Label.IsVisible>
                                                <MultiBinding Converter="{StaticResource MsrpVisibleWhenDiscountConverter}">
                                                    <Binding Path="MsrpPrice" />
                                                    <Binding Path="DealerPrice" />
                                                </MultiBinding>
                                            </Label.IsVisible>
                                        </Label>

                                        <Button Text="Sepete ekle"
                                                SemanticProperties.Hint="Bu ürünü sepete ekler"
                                                Margin="0,4,0,0"
                                                BackgroundColor="Transparent"
                                                BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                                BorderWidth="1"
                                                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                                HeightRequest="40"
                                                CornerRadius="12"
                                                Padding="12,8"
                                                Command="{Binding BindingContext.AddToCartQuickCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
