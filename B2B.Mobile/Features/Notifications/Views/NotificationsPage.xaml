<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Notifications.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:contracts="clr-namespace:B2B.Contracts;assembly=B2B.Contracts"
    xmlns:shell="clr-namespace:B2B.Mobile.Core.Shell"
    xmlns:ui="clr-namespace:B2B.Mobile.Core.Ui;assembly=B2B.Mobile"
    xmlns:vm="clr-namespace:B2B.Mobile.Features.Notifications.ViewModels"
    x:DataType="vm:NotificationsViewModel"
    Title="Bildirimler">

    <Grid RowDefinitions="Auto,*">
        <shell:MainHeaderView Grid.Row="0" Padding="16,12,16,0" />

        <Grid Grid.Row="1">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <VerticalStackLayout Padding="16" Spacing="12">
                <ui:ApiErrorBannerView Message="{Binding Error}" TraceId="{Binding ApiTraceId}" />

                <CollectionView
                    ItemsSource="{Binding Items}"
                    RemainingItemsThreshold="5"
                    RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                    SelectionMode="Single"
                    SelectionChanged="OnSelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="contracts:NotificationListItem">
                            <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                    <BoxView Grid.RowSpan="3"
                                             WidthRequest="6"
                                             CornerRadius="3"
                                             BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                             Opacity="{Binding IsRead, Converter={StaticResource InverseBoolToOpacityConverter}}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />

                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Body}"
                                           Style="{StaticResource Caption}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="3" />

                                    <Label Grid.Row="2" Grid.Column="1"
                                           Text="{Binding CreatedAtUtc, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                           Style="{StaticResource Caption}"
                                           Opacity="0.7" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="Yenile" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>

