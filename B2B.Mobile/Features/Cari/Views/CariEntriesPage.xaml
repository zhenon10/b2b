<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Cari.Views.CariEntriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shell="clr-namespace:B2B.Mobile.Core.Shell"
    xmlns:ui="clr-namespace:B2B.Mobile.Core.Ui;assembly=B2B.Mobile"
    xmlns:contracts="clr-namespace:B2B.Contracts;assembly=B2B.Contracts"
    xmlns:vm="clr-namespace:B2B.Mobile.Features.Cari.ViewModels"
    x:DataType="vm:CariEntriesViewModel"
    Title="{Binding TitleLine}">

    <Grid RowDefinitions="Auto,*">
        <shell:MainHeaderView Grid.Row="0" Padding="16,12,16,0" />

        <Grid Grid.Row="1">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <VerticalStackLayout Padding="16" Spacing="12">
                <ui:ApiErrorBannerView Message="{Binding Error}" TraceId="{Binding ApiTraceId}" />

                <CollectionView
                    ItemsSource="{Binding Items}"
                    RemainingItemsThreshold="5"
                    RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="24" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="Hareket yok" Style="{StaticResource Title2}" HorizontalTextAlignment="Center" />
                            <Label Text="Bu cari hesap için henüz hareket oluşmamış." Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="contracts:CustomerAccountEntryDto">
                            <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                    <Label Text="{Binding Type}" FontAttributes="Bold" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Amount, StringFormat='{0:0.##}'}"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="End" />

                                    <Label Grid.Row="1" Text="{Binding CreatedAtUtc, StringFormat='{0:dd.MM.yyyy HH:mm}'}" Style="{StaticResource Caption}" Opacity="0.7" />
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding CurrencyCode}" Style="{StaticResource Caption}" Opacity="0.7" HorizontalTextAlignment="End" />

                                    <Label Grid.Row="2" Grid.ColumnSpan="2"
                                           Text="{Binding OrderNumber, StringFormat='Sipariş: #{0}'}"
                                           Style="{StaticResource Caption}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding OrderNumber}" Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="Yenile" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>

