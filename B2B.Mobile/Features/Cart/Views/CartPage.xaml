<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Cart.Views.CartPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shell="clr-namespace:B2B.Mobile.Core.Shell"
    x:Name="CartPageRoot"
    Title="Sepet">

    <Grid RowDefinitions="Auto,*,Auto" Padding="12" RowSpacing="10">
        <shell:MainHeaderView Grid.Row="0" />
        <CollectionView Grid.Row="1" ItemsSource="{Binding Lines}">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24" Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="Sepetiniz boş" Style="{StaticResource Title}" HorizontalTextAlignment="Center" />
                    <Label Text="Sipariş vermek için ürün ekleyin." Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                            <Button Grid.Row="0" Grid.Column="1" Text="Kaldır"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BindingContext.RemoveCommand, Source={x:Reference Name=CartPageRoot}}"
                                    CommandParameter="{Binding .}" />

                            <Label Grid.Row="1" Grid.Column="0" Text="{Binding Sku}" Style="{StaticResource Caption}" />

                            <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="10">
                                <Label Text="{Binding Quantity, StringFormat='Adet: {0}'}" Style="{StaticResource Caption}" />
                                <Label Text="{Binding UnitPrice, StringFormat='Birim: {0:0.##}'}" Style="{StaticResource Caption}" />
                                <Label Text="{Binding LineTotal, StringFormat='Satır: {0:0.##}'}" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Toplam" Style="{StaticResource Caption}" />
                    <Label Text="{Binding Total, StringFormat='{0:0.##}'}" FontAttributes="Bold" FontSize="18" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="Temizle" Style="{StaticResource SecondaryButton}" Command="{Binding ClearCommand}" />
                <Button Grid.Column="2" Text="Siparişe geç" Command="{Binding CheckoutCommand}" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
