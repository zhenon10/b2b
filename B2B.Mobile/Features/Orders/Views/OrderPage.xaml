<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="B2B.Mobile.Features.Orders.Views.OrderPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shell="clr-namespace:B2B.Mobile.Core.Shell"
    xmlns:ui="clr-namespace:B2B.Mobile.Core.Ui"
    xmlns:models="clr-namespace:B2B.Mobile.Features.Orders.Models"
    x:Name="OrderPageRoot"
    Title="Sipariş">

    <Grid RowDefinitions="Auto,*">
        <shell:MainHeaderView Grid.Row="0" Padding="16,12,16,0" />

        <!-- Bayi: sepet + sipariş geçmişi -->
        <Grid x:Name="DealerSection" Grid.Row="1" RowDefinitions="Auto,*" IsVisible="True">
            <HorizontalStackLayout Grid.Row="0" Padding="16,12,16,8" Spacing="10">
                <Button Text="Sepetim"
                        HorizontalOptions="FillAndExpand"
                        Command="{Binding ShowCartPanelCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsCartPanel}" Value="False">
                            <Setter Property="Style" Value="{StaticResource SecondaryButton}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="Siparişlerim"
                        HorizontalOptions="FillAndExpand"
                        Command="{Binding ShowHistoryPanelCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsHistoryPanel}" Value="False">
                            <Setter Property="Style" Value="{StaticResource SecondaryButton}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>

            <ScrollView Grid.Row="1" IsVisible="{Binding IsCartPanel}">
                <Grid Padding="16,0,16,16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="14">
                    <VerticalStackLayout Grid.Row="0" Spacing="6">
                        <Label Text="Siparişi gönder" Style="{StaticResource Title}" />
                        <Label Text="Önce sepeti kontrol edin, sonra siparişi gönderin." Style="{StaticResource Caption}" />
                    </VerticalStackLayout>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Sipariş özeti" FontAttributes="Bold" />
                            <Label Text="{Binding SellerSummary}" Style="{StaticResource Caption}" />

                            <Grid ColumnDefinitions="*,Auto" RowSpacing="6">
                                <Label Grid.Column="0" Text="Toplam" Style="{StaticResource Caption}" />
                                <Label Grid.Column="1" Text="{Binding TotalWithCurrency}" FontAttributes="Bold" />
                            </Grid>

                            <Button Text="Sepeti düzenle"
                                    Style="{StaticResource SecondaryButton}"
                                    SemanticProperties.Hint="Sepet sekmesine gider"
                                    Command="{Binding GoToCartCommand}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12"
                            IsVisible="{Binding HasCartLines, Converter={StaticResource InverseBoolConverter}}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Sepet boş" Style="{StaticResource Title2}" />
                            <Label Text="Sipariş oluşturmak için kataloğa dönüp ürün ekleyin." Style="{StaticResource Caption}" />
                            <Button Text="Ürünlere git"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding GoToProductsCommand}" />
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout
                        Grid.Row="3"
                        Spacing="10"
                        IsVisible="{Binding Error, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <ui:ApiErrorBannerView Message="{Binding Error}" TraceId="{Binding ErrorTraceId}" />
                        <HorizontalStackLayout Spacing="10">
                            <Button Text="Tekrar dene"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RetrySubmitCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                            <Button Text="Yeni anahtar"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RetryWithNewKeyCommand}"
                                    IsVisible="{Binding CanRetryWithNewKey}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Border Grid.Row="4" Style="{StaticResource Card}" Padding="12"
                            IsVisible="{Binding Result, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <Label Text="{Binding Result}" TextColor="{StaticResource Success}" />
                    </Border>

                    <Border Grid.Row="5" Style="{StaticResource Card}" Padding="12" IsVisible="{Binding HasCartLines}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="Siparişi gönder"
                                    Command="{Binding SubmitCommand}"
                                    IsEnabled="{Binding CanSubmit}" />
                        </Grid>
                    </Border>
                </Grid>
            </ScrollView>

            <RefreshView Grid.Row="1"
                         IsVisible="{Binding IsHistoryPanel}"
                         IsRefreshing="{Binding IsHistoryRefreshing}"
                         Command="{Binding RefreshHistoryCommand}">
                <ScrollView x:Name="HistoryScroll">
                    <VerticalStackLayout Padding="16,0,16,16" Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Siparişlerim" Style="{StaticResource Title}" />
                                <Label Text="Geçmiş siparişlerinizi buradan takip edebilirsiniz."
                                       Style="{StaticResource Caption}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="Yenile"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RefreshHistoryCommand}"
                                    IsEnabled="{Binding IsHistoryBusy, Converter={StaticResource InverseBoolConverter}}" />
                        </Grid>

                        <VerticalStackLayout
                                Spacing="10"
                                IsVisible="{Binding HistoryError, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                            <ui:ApiErrorBannerView Message="{Binding HistoryError}" TraceId="{Binding HistoryErrorTraceId}" />
                                <Button Text="Tekrar dene"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding RetryHistoryCommand}"
                                        IsEnabled="{Binding IsHistoryBusy, Converter={StaticResource InverseBoolConverter}}" />
                        </VerticalStackLayout>

                        <ActivityIndicator IsRunning="{Binding IsHistoryBusy}" IsVisible="{Binding IsHistoryBusy}" />

                        <CollectionView ItemsSource="{Binding HistoryItems}" SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Border Style="{StaticResource Card}" Padding="12">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="Henüz sipariş yok" Style="{StaticResource Title2}" />
                                        <Label Text="Ürünler sekmesinden sepete ürün ekleyip sipariş oluşturabilirsiniz."
                                               Style="{StaticResource Caption}" />
                                        <Button Text="Ürünlere git"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding GoToProductsCommand}" />
                                    </VerticalStackLayout>
                                </Border>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:DealerOrderListItem">
                                    <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.SelectHistoryOrderCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid Padding="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                            <Label Grid.Row="0" Grid.Column="0" FontAttributes="Bold" Text="{Binding OrderNumber, StringFormat='Sipariş #{0}'}" />
                                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4" VerticalOptions="Start">
                                                <Label FontAttributes="Bold" Text="{Binding GrandTotal, StringFormat='{0:0.##}'}" />
                                                <Label FontAttributes="Bold" Text="{Binding CurrencyCode}" />
                                            </HorizontalStackLayout>
                                            <Label Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Caption}"
                                                   Text="{Binding Status, Converter={StaticResource OrderStatusLabelConverter}, StringFormat='Durum: {0}'}" />
                                            <Label Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource Caption}"
                                                   Text="{Binding CreatedAtUtc, StringFormat='{0:dd.MM.yyyy HH:mm}'}" />
                                            <Label Grid.Row="3" Grid.ColumnSpan="2" Style="{StaticResource Caption}" LineBreakMode="TailTruncation"
                                                   Text="{Binding SellerDisplayName, StringFormat='Satıcı: {0}', TargetNullValue='Satıcı: —'}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                            <Button Text="Önceki"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding HistoryPrevPageCommand}"
                                    IsEnabled="{Binding CanHistoryPrev}" />
                            <Label Grid.Column="1"
                                   VerticalOptions="Center"
                                   Style="{StaticResource Caption}"
                                   Text="{Binding HistoryPageSummary}" />
                            <Button Grid.Column="2"
                                    Text="Sonraki"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding HistoryNextPageCommand}"
                                    IsEnabled="{Binding CanHistoryNext}" />
                        </Grid>

                        <Border x:Name="HistoryDetailCard"
                                IsVisible="{Binding HasHistoryDetail}"
                                Style="{StaticResource Card}"
                                Padding="12">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label FontAttributes="Bold"
                                           Text="{Binding SelectedHistoryDetail.OrderNumber, StringFormat='Sipariş #{0}', TargetNullValue=''}" />
                                    <Button Grid.Column="1"
                                            Text="Kapat"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding CloseHistoryDetailCommand}" />
                                </Grid>
                                <Label FontAttributes="Bold" Text="{Binding HistoryDetailStatusLine}" />
                                <Label Style="{StaticResource Caption}"
                                       Text="{Binding SelectedHistoryDetail.SellerDisplayName, StringFormat='Satıcı: {0}', TargetNullValue='Satıcı: —'}" />
                                <Label FontAttributes="Bold" Text="{Binding HistoryDetailTotalLine}" />
                                <Label Style="{StaticResource Caption}"
                                       Text="{Binding SelectedHistoryDetail.CreatedAtUtc, StringFormat='Oluşturulma: {0:dd.MM.yyyy HH:mm}', TargetNullValue=''}" />

                                <CollectionView ItemsSource="{Binding SelectedHistoryDetail.Items}" HeightRequest="220">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:DealerOrderLine">
                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" Padding="0,4" ColumnSpacing="6">
                                                <Label Grid.Column="0" LineBreakMode="TailTruncation" Text="{Binding ProductName}" />
                                                <Label Grid.Column="1" Style="{StaticResource Caption}" Text="{Binding Quantity, StringFormat='x{0}'}" />
                                                <Label Grid.Column="2" Text="{Binding UnitPrice, StringFormat='{0:0.##}'}" />
                                                <Label Grid.Column="3" Style="{StaticResource Caption}"
                                                       Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectedHistoryDetail.CurrencyCode}" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                                <Label Style="{StaticResource Caption}"
                                       Text="{Binding SelectedHistoryDetail.CurrencyCode, StringFormat='Satır birim fiyatları ({0})', TargetNullValue=''}" />

                                <ui:ApiErrorBannerView Message="{Binding HistoryDetailError}" TraceId="{Binding HistoryDetailErrorTraceId}" />

                                <Button Text="Tekrar dene"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding RefreshSelectedHistoryDetailCommand}"
                                        IsVisible="{Binding HistoryDetailError, Converter={StaticResource StringNotNullOrEmptyConverter}}"
                                        IsEnabled="{Binding IsHistoryDetailBusy, Converter={StaticResource InverseBoolConverter}}" />

                                <Button Text="Siparişi iptal et"
                                        TextColor="{StaticResource Error}"
                                        Command="{Binding CancelSelectedOrderCommand}"
                                        IsVisible="{Binding CanCancelSelectedOrder}" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>
        </Grid>
    </Grid>
</ContentPage>
