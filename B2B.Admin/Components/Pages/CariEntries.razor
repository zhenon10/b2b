@page "/cari/entries/{BuyerUserId:guid}/{SellerUserId:guid}/{CurrencyCode}"
@using B2B.Contracts
@inject B2B.Admin.Services.B2BApiClient Api
@inject B2B.Admin.Services.AdminUiNotify Notify

<PageTitle>Cari Ekstre</PageTitle>

<h3>Cari Ekstre</h3>
<div class="small text-muted mb-3">
    Buyer: <code>@BuyerUserId</code> • Seller: <code>@SellerUserId</code> • @CurrencyCode
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">
        <div>@error</div>
        @if (!string.IsNullOrWhiteSpace(traceId))
        {
            <div class="small text-muted">trace: @traceId</div>
        }
    </div>
}

@if (items is not null)
{
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Tarih</th>
            <th>Tip</th>
            <th>Sipariş</th>
            <th class="text-end">Tutar</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var row in items.Items)
        {
            <tr>
                <td>@row.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@row.Type</td>
                <td>@(row.OrderNumber.HasValue ? $"#{row.OrderNumber}" : "-")</td>
                <td class="text-end">@row.Amount.ToString("0.##") @row.CurrencyCode</td>
            </tr>
        }
        </tbody>
    </table>

    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-sm btn-outline-secondary" @onclick="PrevAsync" disabled="@(!CanPrev || isBusy)">Önceki</button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="NextAsync" disabled="@(!CanNext || isBusy)">Sonraki</button>
        <span class="small text-muted">Sayfa @currentPage / @TotalPages</span>
    </div>
}

@code {
    [Parameter] public Guid BuyerUserId { get; set; }
    [Parameter] public Guid SellerUserId { get; set; }
    [Parameter] public string CurrencyCode { get; set; } = "";

    private bool isBusy;
    private string? error;
    private string? traceId;

    private int currentPage = 1;
    private const int PageSize = 50;
    private PagedResult<CustomerAccountEntryDto>? items;

    private int TotalPages => items?.Meta.Total is > 0
        ? (int)Math.Ceiling(items!.Meta.Total / (double)items!.Meta.PageSize)
        : 1;

    private bool CanPrev => currentPage > 1;
    private bool CanNext => items is not null && (currentPage * PageSize) < items.Meta.Total;

    protected override async Task OnParametersSetAsync()
    {
        currentPage = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        error = null;
        traceId = null;
        items = null;

        if (BuyerUserId == Guid.Empty || SellerUserId == Guid.Empty || string.IsNullOrWhiteSpace(CurrencyCode))
        {
            error = "Parametreler eksik.";
            return;
        }

        isBusy = true;
        try
        {
            var resp = await Api.GetCustomerCariEntriesAsync(BuyerUserId, SellerUserId, CurrencyCode, currentPage, PageSize);
            if (!resp.Success || resp.Data is null)
            {
                error = resp.Error?.Message ?? "Ekstre yüklenemedi.";
                traceId = resp.TraceId;
                Notify.Raise(new AdminToast("Hata", error, AdminToastKind.Danger));
                return;
            }

            items = resp.Data;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task PrevAsync()
    {
        if (!CanPrev) return;
        currentPage--;
        await LoadAsync();
    }

    private async Task NextAsync()
    {
        if (!CanNext) return;
        currentPage++;
        await LoadAsync();
    }
}

