@inherits LayoutComponentBase
@implements IDisposable
@inject AdminUiNotify UiNotify

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">Hakkında</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@if (_toast is not null)
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1080; max-width: 22rem;">
        <div class="@ToastCssClass shadow" role="status" aria-live="polite">
            <div class="d-flex align-items-start">
                <div class="flex-grow-1">
                    <div class="fw-semibold">@_toast!.Title</div>
                    <div class="small mt-1">@_toast.Message</div>
                </div>
                <button type="button" class="btn-close btn-sm ms-2" aria-label="Kapat" @onclick="DismissToast"></button>
            </div>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    Beklenmeyen bir hata oluştu.
    <a href="." class="reload">Yenile</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private AdminToast? _toast;
    private System.Timers.Timer? _dismissTimer;

    private string ToastCssClass => _toast!.Kind switch
    {
        AdminToastKind.Warning => "alert alert-warning rounded p-3 mb-0",
        AdminToastKind.Danger => "alert alert-danger rounded p-3 mb-0",
        _ => "alert alert-info rounded p-3 mb-0"
    };

    protected override void OnInitialized()
    {
        UiNotify.Toast += OnToast;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            UiNotify.AttachUiContext();
    }

    private void OnToast(AdminToast toast)
    {
        _dismissTimer?.Stop();
        _dismissTimer?.Dispose();
        _toast = toast;
        _ = InvokeAsync(StateHasChanged);

        var ms = toast.Kind == AdminToastKind.Info ? 5000 : 9000;
        _dismissTimer = new System.Timers.Timer(ms) { AutoReset = false };
        _dismissTimer.Elapsed += (_, _) =>
        {
            _toast = null;
            _ = InvokeAsync(StateHasChanged);
        };
        _dismissTimer.Start();
    }

    private void DismissToast()
    {
        _dismissTimer?.Stop();
        _toast = null;
        StateHasChanged();
    }

    public void Dispose()
    {
        UiNotify.Toast -= OnToast;
        _dismissTimer?.Stop();
        _dismissTimer?.Dispose();
    }
}
